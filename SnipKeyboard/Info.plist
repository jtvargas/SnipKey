<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<!-- The keyboard attempts a direct EventKit write under "try direct"; the main app owns the
	     permission prompt. Present in the extension's Info.plist so its process is allowed to
	     touch EventKit when the grant is shared. -->
	<key>NSRemindersFullAccessUsageDescription</key>
	<string>SnipKey adds your reminders to Apple Reminders when you choose the Reminders app as your destination in Integrations.</string>
	<key>NSRemindersUsageDescription</key>
	<string>SnipKey adds your reminders to Apple Reminders when you choose the Reminders app as your destination in Integrations.</string>
	<!-- Unlock 120Hz ProMotion for CADisplayLink-driven work in the extension.
	     Must be validated empirically in-extension (host provides the surface). -->
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>NSExtension</key>
	<dict>
		<key>NSExtensionAttributes</key>
		<dict>
			<key>IsASCIICapable</key>
			<false/>
			<key>PrefersRightToLeft</key>
			<false/>
			<key>PrimaryLanguage</key>
			<string>en-US</string>
			<key>RequestsOpenAccess</key>
			<true/>
		</dict>
		<key>NSExtensionPointIdentifier</key>
		<string>com.apple.keyboard-service</string>
		<key>NSExtensionPrincipalClass</key>
		<string>$(PRODUCT_MODULE_NAME).KeyboardViewController</string>
	</dict>
</dict>
</plist>
